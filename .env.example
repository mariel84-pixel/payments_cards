# ─────────────────────────────────────────────
# ÚNICO VALOR QUE NECESITÁS CONFIGURAR:
# ─────────────────────────────────────────────
# Obtenerlo en: https://www.mercadopago.com.ar/developers/panel/app
# → Tus integraciones → (seleccionar app) → Credenciales de prueba → Access Token
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# OPCIONAL — no modificar salvo entorno custom
# ─────────────────────────────────────────────
MP_BASE_URL=https://api.mercadopago.com

# NOTA: El card token de prueba se genera automáticamente.
# No hace falta configurar ningún token de tarjeta.
